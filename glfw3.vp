{
    buttons : uint8[15];
    axes : float32[6];
}

pub struct GLFWallocator
{
    allocate : GLFWallocatefun;
    reallocate : GLFWreallocatefun;
    deallocate : GLFWdeallocatefun;
    user : void*;
}

