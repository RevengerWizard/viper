pub alias GLFWallocatefun = fn(size : uint64, user : void*) : void*;
pub alias GLFWreallocatefun = fn(block : void*, size : uint64, user : void*) : void*;
pub alias GLFWdeallocatefun = fn(block : void*, user : void*) : void;
pub alias GLFWerrorfun = fn(error_code : int32, description : const uint8*) : void;
pub alias GLFWwindowposfun = fn(window : GLFWwindow*, xpos : int32, ypos : int32) : void;
pub alias GLFWwindowsizefun = fn(window : GLFWwindow*, width : int32, height : int32) : void;
pub alias GLFWwindowclosefun = fn(window : GLFWwindow*) : void;
pub alias GLFWwindowrefreshfun = fn(window : GLFWwindow*) : void;
pub alias GLFWwindowfocusfun = fn(window : GLFWwindow*, focused : int32) : void;
pub alias GLFWwindowiconifyfun = fn(window : GLFWwindow*, iconified : int32) : void;
pub alias GLFWwindowmaximizefun = fn(window : GLFWwindow*, maximized : int32) : void;
pub alias GLFWframebuffersizefun = fn(window : GLFWwindow*, width : int32, height : int32) : void;
pub alias GLFWwindowcontentscalefun = fn(window : GLFWwindow*, xscale : float32, yscale : float32) : void;
pub alias GLFWmousebuttonfun = fn(window : GLFWwindow*, button : int32, action : int32, mods : int32) : void;
pub alias GLFWcursorposfun = fn(window : GLFWwindow*, xpos : float64, ypos : float64) : void;
pub alias GLFWcursorenterfun = fn(window : GLFWwindow*, entered : int32) : void;
pub alias GLFWscrollfun = fn(window : GLFWwindow*, xoffset : float64, yoffset : float64) : void;
pub alias GLFWkeyfun = fn(window : GLFWwindow*, key : int32, scancode : int32, action : int32, mods : int32) : void;
pub alias GLFWcharfun = fn(window : GLFWwindow*, codepoint : uint32) : void;
pub alias GLFWcharmodsfun = fn(window : GLFWwindow*, codepoint : uint32, mods : int32) : void;
pub alias GLFWdropfun = fn(window : GLFWwindow*, path_count : int32, paths : const uint8**) : void;
pub alias GLFWmonitorfun = fn(monitor : GLFWmonitor*, event : int32) : void;
pub alias GLFWjoystickfun = fn(jid : int32, event : int32) : void;

pub struct GLFWvidmode
{
    width : int32;
    height : int32;
    redBits : int32;
    greenBits : int32;
    blueBits : int32;
