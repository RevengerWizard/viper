// Code loading and execution (load and run Teascript code)
pub extern fn tea_call(T : tea_State*, n : int32) : void;
pub extern fn tea_pcall(T : tea_State*, n : int32) : int32;
pub extern fn tea_pccall(T : tea_State*, func : tea_CFunction, ud : void*) : int32;
pub extern fn tea_loadx(T : tea_State*, reader : tea_Reader, data : void*, name : const uint8*, mode : const uint8*) : int32;
pub extern fn tea_load(T : tea_State*, reader : tea_Reader, data : void*, name : const uint8*) : int32;
pub extern fn tea_dump(T : tea_State*, writer : tea_Writer, data : void*) : int32;
pub extern fn tea_load_filex(T : tea_State*, filename : const uint8*, name : const uint8*?, mode : const uint8*) : int32;
pub extern fn tea_load_file(T : tea_State*, filename : const uint8*, name : const uint8*?) : int32;
pub extern fn tea_load_bufferx(T : tea_State*, buffer : const uint8*, size : usize, name : const uint8*, mode : const uint8*) : int32;
pub extern fn tea_load_buffer(T : tea_State*, buffer : const uint8*, size : usize, name : const uint8*) : int32;
