// Error handling
pub extern fn tea_throw(T : tea_State*) : void;
pub extern fn tea_error(T : tea_State*, fmt : const uint8*/*, ...*/) : int32;
pub extern fn tea_arglimit_error(T : tea_State*, narg : int32, msg : const uint8*) : int32;
pub extern fn tea_arg_error(T : tea_State*, narg : int32, msg : const uint8*) : int32;
pub extern fn tea_type_error(T : tea_State*, narg : int32, xname : const uint8*) : int32;

// String operations
pub extern fn tea_concat(T : tea_State*, n : int32) : void;

pub inline fn tea_open() : tea_State*
{
    return tea_new_state(nil, nil);
}

pub inline fn tea_do_file(T : tea_State*, f : const uint8*) : int32
{
    return tea_load_file(T, f, nil) or tea_pcall(T, 0);
}

pub inline fn tea_is_mask(T : tea_State*, n : int32, m : int32) : bool
{
    return (tea_get_mask(T, n) & m) != 0;
}

pub inline fn tea_is_nonenil(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) <= TEA_TYPE_NIL;
}

pub inline fn tea_is_none(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_NONE;
}

pub inline fn tea_is_nil(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_NIL;
}

pub inline fn tea_is_bool(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_BOOL;
}

pub inline fn tea_is_number(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_NUMBER;
}

pub inline fn tea_is_pointer(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_POINTER;
}

pub inline fn tea_is_range(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_RANGE;
}

pub inline fn tea_is_string(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_STRING;
}

pub inline fn tea_is_list(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_LIST;
}

pub inline fn tea_is_map(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_MAP;
}

pub inline fn tea_is_function(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_FUNCTION;
}

pub inline fn tea_is_module(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_MODULE;
}

pub inline fn tea_is_class(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_CLASS;
}

pub inline fn tea_is_instance(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_INSTANCE;
}

pub inline fn tea_is_userdata(T : tea_State*, n : int32) : bool
{
    return tea_get_type(T, n) == TEA_TYPE_USERDATA;
}