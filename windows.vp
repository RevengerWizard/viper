pub def WGL_TYPE_RGBA_ARB : int32 = 0x202B;
pub def WGL_TYPE_COLORINDEX_ARB : int32 = 0x202C;

pub def WGL_CONTEXT_MAJOR_VERSION_ARB : int32 = 0x2091;
pub def WGL_CONTEXT_MINOR_VERSION_ARB : int32 = 0x2092;
pub def WGL_CONTEXT_LAYER_PLANE_ARB : int32 = 0x2093;
pub def WGL_CONTEXT_FLAGS_ARB : int32 = 0x2094;
pub def WGL_CONTEXT_PROFILE_MASK_ARB : int32 = 0x9126;
pub def WGL_CONTEXT_DEBUG_BIT_ARB : int32 = 0x00000001;
pub def WGL_CONTEXT_FORWARD_COMPATIBLE_BIT_ARB : int32 = 0x00000002;
pub def WGL_CONTEXT_CORE_PROFILE_BIT_ARB : int32 = 0x00000001;
pub def WGL_CONTEXT_COMPATIBILITY_PROFILE_BIT_ARB : int32 = 0x00000002;

// WGL extensions
pub alias PFNWGLCHOOSEPIXELFORMATARB = fn(HDC, const int32*, const float32*, uint32, int32*, uint32*) : BOOL;
pub alias PFNWGLCREATECONTEXTATTRIBSARB = fn(HDC, HGLRC, const int32*) : HGLRC;

pub extern fn ChoosePixelFormat(hdc : HDC, ppfd : const PIXELFORMATDESCRIPTOR*) : int32;
pub extern fn SetPixelFormat(hdc : HDC, format : int32, ppfd : const PIXELFORMATDESCRIPTOR*) : BOOL;
pub extern fn SwapBuffers(unnamedParam1 : HDC) : BOOL;
pub extern fn wglCreateContext(hdc : HDC) : HGLRC;
pub extern fn wglDeleteContext(hglrc : HGLRC) : BOOL;
pub extern fn wglMakeCurrent(hdc : HDC?, hglrc : HGLRC?) : BOOL;
pub extern fn wglGetCurrentContext() : HGLRC;
pub extern fn wglGetCurrentDC() : HDC;
pub extern fn wglGetProcAddress(lpszProc : LPCSTR) : FARPROC;

/* -- fileapi.h ----------------------------------------------------- */

// File access modes
pub def GENERIC_READ_FLAG : DWORD = 0x80000000;
pub def GENERIC_WRITE : DWORD = 0x40000000;
pub def GENERIC_WRITE_FLAG : DWORD = 0x40000000;
pub def GENERIC_APPEND_FLAG : DWORD = 0x00000004;

// File sharing
pub def FILE_SHARE_READ_FLAG : DWORD = 0x00000001;

// Creation disposition
pub def CREATE_NEW_D : DWORD = 1;
pub def CREATE_ALWAYS : DWORD = 2;
pub def CREATE_ALWAYS_D : DWORD = 2;
pub def OPEN_EXISTING : DWORD = 3;
pub def OPEN_ALWAYS : DWORD = 4;
pub def TRUNCATE_EXISTING : DWORD = 5;

// File attributes
pub def FILE_ATTRIBUTE_NORMAL : DWORD = 128;
pub def FILE_FLAG_APPEND : DWORD = 0x00000004;

// File pointer movement
pub def FILE_BEGIN : DWORD = 0;
pub def FILE_CURRENT : DWORD = 1;
pub def FILE_END_D : DWORD = 2;

// File type
pub def FILE_TYPE_CHAR : DWORD = 0x0002;

pub def INVALID_SET_FILE_POINTER : DWORD = 0xFFFFFFFF;

// File I/O
pub extern fn CreateFileA(lpFileName : LPCSTR, dwDesiredAccess : DWORD, dwShareMode : DWORD, lpSecurityAttributes : LPSECURITY_ATTRIBUTES?, dwCreationDisposition : DWORD, dwFlagsAndAttributes : DWORD, hTemplateFile : HANDLE?) : HANDLE;
pub extern fn ReadFile(hFile : HANDLE, lpBuffer : LPVOID, nNumberOfBytesToRead : DWORD, lpNumberOfBytesRead : LPDWORD, lpOverlapped : LPOVERLAPPED?) : BOOL;
pub extern fn WriteFile(hFile : HANDLE, lpBuffer : LPCVOID, nNumberOfBytesToWrite : DWORD, lpNumberOfBytesWritten : LPDWORD, lpOverlapped : LPOVERLAPPED?) : BOOL;
pub extern fn SetFilePointer(hFile : HANDLE, lDistanceToMove : LONG, lpDistanceToMoveHigh : LONG*?, dwMoveMethod : DWORD) : DWORD;
pub extern fn FlushFileBuffers(hFile : HANDLE) : BOOL;
pub extern fn GetFileType(hFile : HANDLE) : DWORD;

/* -- errhandlingapi.h ---------------------------------------------- */

// Error codes
pub def ERROR_FILE_NOT_FOUND : DWORD = 2;
pub def ERROR_PATH_NOT_FOUND : DWORD = 3;
pub def ERROR_ACCESS_DENIED : DWORD = 5;
pub def ERROR_HANDLE_EOF : DWORD = 38;
pub def ERROR_BROKEN_PIPE : DWORD = 109;
pub def ERROR_NO_DATA : DWORD = 232;

pub extern fn GetLastError() : DWORD;

/* -- handleapi.h --------------------------------------------------- */

pub extern fn CloseHandle(hObject : HANDLE) : BOOL;

/* -- synchapi.h ---------------------------------------------------- */

pub extern fn Sleep(dwMilliseconds : DWORD) : VOID;

/* -- processthreadsapi.h ------------------------------------------- */

pub noreturn extern fn ExitProcess(uExitCode : UINT) : VOID;

/* -- libloaderapi.h ------------------------------------------------ */

pub extern fn LoadLibraryA(lpLibFileName : LPCSTR) : HMODULE;
pub extern fn FreeLibrary(hLibModule : HMODULE) : BOOL;
pub extern fn GetModuleHandleA(lpModuleName : LPCSTR?) : HMODULE;
pub extern fn GetProcAddress(hModule : HMODULE, lpProcName : LPCSTR) : FARPROC;

/* -- consoleapi.h -------------------------------------------------- */

pub extern fn WriteConsoleA(h : HANDLE, buf : const uint8*, n : DWORD, nw : LPDWORD?, _ : void*?) : bool;
pub extern fn ReadConsoleA(h : HANDLE, buf : LPVOID, n : DWORD, nr : LPDWORD, _ : void*?) : BOOL;

/* -- processenv.h -------------------------------------------------- */

pub extern fn GetStdHandle(std : DWORD) : HANDLE;