// Win32 API bindings

/* -- winnt.h ------------------------------------------------------- */

pub alias VOID = void;
pub alias PVOID = void*;
pub alias LPVOID = void*;
pub alias LPCVOID = const void*;

pub alias BYTE = uint8;
pub alias WORD = uint16;
pub alias DWORD = uint32;
pub alias LONG = int32;
pub alias UINT = uint32;

pub alias INT_PTR = int64;
pub alias LONG_PTR = int64;
pub alias UINT_PTR = uint64;
pub alias ULONG_PTR = uint64;
pub alias SIZE_T = ULONG_PTR;

pub alias HANDLE = void*;
pub alias BOOL = int32;
pub alias WINBOOL = int32;

pub alias LPDWORD = DWORD*;
pub alias DWORD_PTR = DWORD*;

/* -- windef.h ------------------------------------------------------ */

pub alias HWND = HANDLE;
pub alias HMENU = HANDLE;
pub alias HINSTANCE = HANDLE;
pub alias HMODULE = HANDLE;
pub alias HICON = HANDLE;
pub alias HCURSOR = HANDLE;
pub alias HBRUSH = HANDLE;
pub alias HDC = HANDLE;
pub alias HGLRC = HANDLE;

pub alias ATOM = uint16;
pub alias WPARAM = UINT_PTR;
pub alias LPARAM = LONG_PTR;
pub alias LRESULT = LONG_PTR;

pub alias LPCSTR = const uint8*;
pub alias FARPROC = fn() : INT_PTR;
pub alias WNDPROC = fn(HWND, UINT, WPARAM, LPARAM) : LRESULT;

pub struct POINT
{
    x, y : LONG;
}

/* -- winbase.h ----------------------------------------------------- */

pub alias LPSECURITY_ATTRIBUTES = void*;
pub alias LPOVERLAPPED = void*;

pub struct FILETIME
{
    dwLowDateTime : DWORD;
    dwHighDateTime : DWORD;
}
pub alias PFILETIME = FILETIME*;
pub alias LPFILETIME = FILETIME*;

// Standard handles
pub def STD_INPUT_HANDLE : DWORD = bitcast(DWORD, -10);
pub def STD_OUTPUT_HANDLE : DWORD = bitcast(DWORD, -11);
pub def STD_ERROR_HANDLE : DWORD = bitcast(DWORD, -12);

/* -- sysinfoapi.h -------------------------------------------------- */

struct SYSTEMTIME
{
    wYear : WORD;
    wMonth : WORD;
    wDayOfWeek : WORD;
    wDay : WORD;
    wHour : WORD;
    wMinute : WORD;
    wSecond : WORD;
    wMilliseconds : WORD;
}
pub alias PSYSTEMTIME = SYSTEMTIME*;
pub alias LPSYSTEMTIME = SYSTEMTIME*;

pub struct SYSTEM_INFO
{
    union
    {
        dwOemId : DWORD;
        struct
        {
            wProcessorArchitecture : WORD;
            wReserved : WORD;
        }
    }
    dwPageSize : DWORD;
    lpMinimumApplicationAddress : LPVOID;
    lpMaximumApplicationAddress : LPVOID;
    dwActiveProcessorMask : DWORD_PTR;
    dwNumberOfProcessors : DWORD;
    dwProcessorType : DWORD;
    dwAllocationGranularity : DWORD;
    wProcessorLevel : WORD;
    wProcessorRevision : WORD;
}
pub alias LPSYSTEM_INFO = SYSTEM_INFO*;

pub extern fn GetSystemInfo(lpSystemInfo : LPSYSTEM_INFO) : VOID;
pub extern fn GetTickCount() : DWORD;
pub extern fn GetSystemTime(lpSystemTime : LPSYSTEMTIME) : void;
pub extern fn GetSystemTimeAsFileTime(lpSystemTimeAsFileTime : LPFILETIME) : void;

/* -- memoryapi.h --------------------------------------------------- */

pub struct MEMORY_BASIC_INFORMATION
{
    BaseAddress : PVOID;
    AllocationBase : PVOID;
    AllocationProtect : DWORD;
    PartitionId : WORD;
    RegionSize : SIZE_T;
    State : DWORD;
    Protect : DWORD;
    Type : DWORD;
}
pub alias PMEMORY_BASIC_INFORMATION = MEMORY_BASIC_INFORMATION*;

// Memory allocation types
pub def MEM_COMMIT : DWORD = 0x1000;
pub def MEM_RESERVE : DWORD = 0x2000;
pub def MEM_RELEASE : DWORD = 0x8000;
pub def MEM_TOP_DOWN : DWORD = 0x100000;
pub def MEM_IMAGE : DWORD = 0x1000000;
pub def MEM_MAPPED : DWORD = 0x40000;
pub def MEM_PRIVATE : DWORD = 0x20000;

// Page protection
pub def PAGE_READWRITE : DWORD = 0x04;

// Memory management
pub extern fn VirtualAlloc(lpAddress : LPVOID?, dwSize : SIZE_T, flAllocationType : DWORD, flProtect : DWORD) : LPVOID;
pub extern fn VirtualQuery(lpAddress : LPCVOID?, lpBuffer : PMEMORY_BASIC_INFORMATION, dwLength : SIZE_T) : SIZE_T;
pub extern fn VirtualFree(lpAddress : LPVOID, dwSize : SIZE_T, dwFreeType : DWORD) : WINBOOL;

/* -- winuser.h ----------------------------------------------------- */

pub struct WNDCLASSA
{
    style : UINT;
    lpfnWndProc : WNDPROC;
    cbClsExtra : int32;
    cbWndExtra : int32;
    hInstance : HINSTANCE;
    hIcon : HICON;
    hCursor : HCURSOR;
    hbrBackground : HBRUSH;
    lpszMenuName : LPCSTR;
    lpszClassName : LPCSTR;
}

// Window styles
pub def WS_OVERLAPPED : UINT = 0x00000000;
pub def WS_POPUP : UINT = 0x80000000;
pub def WS_CHILD : UINT = 0x40000000;
pub def WS_MINIMIZE : UINT = 0x20000000;
pub def WS_VISIBLE : UINT = 0x10000000;
pub def WS_DISABLED : UINT = 0x08000000;
pub def WS_CLIPSIBLINGS : UINT = 0x04000000;
pub def WS_CLIPCHILDREN : UINT = 0x02000000;
pub def WS_MAXIMIZE : UINT = 0x01000000;
pub def WS_CAPTION : UINT = 0x00C00000;
pub def WS_BORDER : UINT = 0x00800000;
pub def WS_DLGFRAME : UINT = 0x00400000;
pub def WS_VSCROLL : UINT = 0x00200000;
pub def WS_HSCROLL : UINT = 0x00100000;
pub def WS_SYSMENU : UINT = 0x00080000;
pub def WS_THICKFRAME : UINT = 0x00040000;
pub def WS_GROUP : UINT = 0x00020000;
pub def WS_TABSTOP : UINT = 0x00010000;
pub def WS_MINIMIZEBOX : UINT = 0x00020000;
pub def WS_MAXIMIZEBOX : UINT = 0x00010000;
pub def WS_TILED : UINT = WS_OVERLAPPED;
pub def WS_ICONIC : UINT = WS_MINIMIZE;
pub def WS_SIZEBOX : UINT = WS_THICKFRAME;
pub def WS_OVERLAPPEDWINDOW : UINT = (WS_OVERLAPPED | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MINIMIZEBOX | WS_MAXIMIZEBOX);
pub def WS_TILEDWINDOW : UINT = WS_OVERLAPPEDWINDOW;

// Window class style
pub def CS_VREDRAW : UINT = 0x0001;
pub def CS_HREDRAW : UINT = 0x0002;
pub def CS_DBLCLKS : UINT = 0x0008;
pub def CS_OWNDC : UINT = 0x0020;

// Window messages
pub def WM_CREATE : UINT = 0x0001;
pub def WM_DESTROY : UINT = 0x0002;
pub def WM_CLOSE : UINT = 0x0010;

pub def CW_USEDEFAULT : int32 = -2147483647 - 1;
pub def SW_SHOW : int32 = 5;

// Message box
pub def MB_OK : UINT = 0x00000000;
pub def MB_OKCANCEL : UINT = 0x00000001;
pub def MB_ABORTRETRYIGNORE : UINT = 0x00000002;
pub def MB_YESNOCANCEL : UINT = 0x00000003;
pub def MB_YESNO : UINT = 0x00000004;
pub def MB_RETRYCANCEL : UINT = 0x00000005;
pub def MB_CANCELTRYCONTINUE : UINT = 0x00000006;
pub def MB_HELP : UINT = 0x00004000;

pub def MB_ICONSTOP : UINT = 0x00000010;
pub def MB_ICONHAND : UINT = MB_ICONSTOP;
pub def MB_ICONERROR : UINT = MB_ICONSTOP;
pub def MB_ICONEXCLAMATION : UINT = 0x00000030;
pub def MB_ICONWARNING : UINT = MB_ICONEXCLAMATION;
pub def MB_ICONQUESTION : UINT = 0x00000020;
pub def MB_ICONINFORMATION : UINT = 0x00000040;
pub def MB_ICONASTERISK : UINT = MB_ICONINFORMATION;

pub def PM_REMOVE : UINT = 0x0001;

// Window long indices
pub def GWLP_WNDPROC : int32 = -4;
pub def GWLP_HINSTANCE : int32 = -6;
pub def GWLP_HWNDPARENT : int32 = -8;
pub def GWLP_ID : int32 = -12;
pub def GWLP_USERDATA : int32 = -21;

// Colors
pub def COLOR_BACKGROUND : int32 = 1;
pub def COLOR_WINDOW : int32 = 5;

pub struct MSG
{
    hwnd : HWND;
    message : UINT;
    wParam : WPARAM;
    lParam : LPARAM;
    time : DWORD;
    pt : POINT;
}
pub alias LPMSG = MSG*;

pub struct CREATESTRUCT
{
    lpCreateParams : LPVOID;
    hInstance : HINSTANCE;
    hMenu : HMENU;
    hwndParent : HWND;
    cy : int32;
    cx : int32;
    y : int32;
    x : int32;
    style : LONG;
    lpszName : LPCSTR;
    lpszClass : LPCSTR;
    dwExStyle : DWORD;
}

// Window management
pub extern fn CreateWindowExA(dwExStyle : DWORD, lpClassName : LPCSTR?, lpWindowName : LPCSTR?, dwStyle : DWORD, X : int32, Y : int32, nWidth : int32, nHeight : int32, hWndParent : HWND?, hMenu : HMENU?, hInstance : HINSTANCE?, lpParam : LPVOID?) : HWND;
pub extern fn RegisterClassA(lpWndClass : WNDCLASSA*) : ATOM;
pub extern fn DefWindowProcA(hWnd : HWND, Msg : UINT, wParam : WPARAM, lParam : LPARAM) : LRESULT;
pub extern fn ShowWindow(hWnd : HWND, nCmdShow : int32) : WINBOOL;
pub extern fn UpdateWindow(hWnd : HWND) : WINBOOL;
pub extern fn GetDC(hWnd : HWND) : HDC;
pub extern fn ReleaseDC(hWnd : HWND, hDC : HDC) : int32;
pub extern fn DestroyWindow(hWnd : HWND) : BOOL;

// Message handling
pub extern fn GetMessageA(lpMsg : MSG*, hWnd : HWND?, wMsgFilterMin : UINT, wMsgFilterMax : UINT) : WINBOOL;
pub extern fn PeekMessageA(lpMsg : LPMSG, hWnd : HWND, wMsgFilterMin : UINT, wMsgFilterMax : UINT, wRemoveMsg : UINT) : BOOL;
pub extern fn DispatchMessageA(lpMsg : MSG*) : LRESULT;
pub extern fn TranslateMessage(lpMsg : MSG*) : WINBOOL;
pub extern fn PostQuitMessage(nExitCode : int32) : void;

// Window userdata
pub extern fn SetWindowLongPtrA(hWnd : HWND, nIndex : int32, dwNewLong : LONG_PTR) : LONG_PTR;
pub extern fn GetWindowLongPtrA(hWnd : HWND, nIndex : int32) : LONG_PTR;

// Message box
pub extern fn MessageBoxA(hWnd : HWND?, lpText : LPCSTR, lpCaption : LPCSTR, uType : UINT) : int32;

/* -- wingdi.h ------------------------------------------------------ */

pub struct PIXELFORMATDESCRIPTOR
{
    nSize : WORD;
    nVersion : WORD;
    dwFlags : DWORD;
    iPixelType : BYTE;
    cColorBits : BYTE;
    cRedBits : BYTE;
    cRedShift : BYTE;
    cGreenBits : BYTE;
    cGreenShift : BYTE;
    cBlueBits : BYTE;
    cBlueShift : BYTE;
    cAlphaBits : BYTE;
    cAlphaShift : BYTE;
    cAccumBits : BYTE;
    cAccumRedBits : BYTE;
    cAccumGreenBits : BYTE;
    cAccumBlueBits : BYTE;
    cAccumAlphaBits : BYTE;
    cDepthBits : BYTE;
    cStencilBits : BYTE;
    cAuxBuffers : BYTE;
    iLayerType : BYTE;
    bReserved : BYTE;
    dwLayerMask : DWORD;
    dwVisibleMask : DWORD;
    dwDamageMask : DWORD;
}

// Pixel format
pub def PFD_DRAW_TO_WINDOW : DWORD = 0x00000004;
pub def PFD_DOUBLEBUFFER : DWORD = 0x00000001;
pub def PFD_SUPPORT_OPENGL : DWORD = 0x00000020;
pub def PFD_TYPE_RGBA : BYTE = 0;
pub def PFD_MAIN_PLANE : BYTE = 0;

