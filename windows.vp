pub def WGL_DRAW_TO_WINDOW_ARB : int32 = 0x2001;
pub def WGL_DRAW_TO_BITMAP_ARB : int32 = 0x2002;
pub def WGL_ACCELERATION_ARB : int32 = 0x2003;
