pub def WGL_DOUBLE_BUFFER_ARB : int32 = 0x2011;
pub def WGL_STEREO_ARB : int32 = 0x2012;
pub def WGL_PIXEL_TYPE_ARB : int32 = 0x2013;
pub def WGL_COLOR_BITS_ARB : int32 = 0x2014;
pub def WGL_RED_BITS_ARB : int32 = 0x2015;
pub def WGL_RED_SHIFT_ARB : int32 = 0x2016;
pub def WGL_GREEN_BITS_ARB : int32 = 0x2017;
pub def WGL_GREEN_SHIFT_ARB : int32 = 0x2018;
pub def WGL_BLUE_BITS_ARB : int32 = 0x2019;
pub def WGL_BLUE_SHIFT_ARB : int32 = 0x201A;
pub def WGL_ALPHA_BITS_ARB : int32 = 0x201B;
pub def WGL_ALPHA_SHIFT_ARB : int32 = 0x201C;
pub def WGL_ACCUM_BITS_ARB : int32 = 0x201D;
pub def WGL_ACCUM_RED_BITS_ARB : int32 = 0x201E;
pub def WGL_ACCUM_GREEN_BITS_ARB : int32 = 0x201F;
pub def WGL_ACCUM_BLUE_BITS_ARB : int32 = 0x2020;
pub def WGL_ACCUM_ALPHA_BITS_ARB : int32 = 0x2021;
pub def WGL_DEPTH_BITS_ARB : int32 = 0x2022;
pub def WGL_STENCIL_BITS_ARB : int32 = 0x2023;
pub def WGL_AUX_BUFFERS_ARB : int32 = 0x2024;
pub def WGL_NO_ACCELERATION_ARB : int32 = 0x2025;
pub def WGL_GENERIC_ACCELERATION_ARB : int32 = 0x2026;
pub def WGL_FULL_ACCELERATION_ARB : int32 = 0x2027;
pub def WGL_SAMPLE_BUFFERS_ARB : int32 = 0x2041;
